# ============================================================
# VAMOS Environment Variables Template
# 이 파일을 .env 로 복사한 후 실제 값을 입력하세요
# cp .env.example .env
# ============================================================

# ── 환경 설정 ──
VAMOS_ENV=development
VAMOS_LOG_LEVEL=debug

# ── LLM API Keys ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (로컬 LLM) ──
OLLAMA_HOST=http://localhost:11434

# ── Storage Paths ──
SQLITE_DB_PATH=./data/vamos.db
CHROMA_PERSIST_DIR=./data/chroma

# ── Cost Control (ABSOLUTE LOCK) ──
VAMOS_COST_DAILY_LIMIT=1300
VAMOS_COST_MONTHLY_LIMIT=40000

# ── MCP Server ──
MCP_SERVER_URL=http://localhost:8080

# ── Embedding ──
# BGE-M3 로컬 사용 시 별도 키 불필요
# OpenAI embedding 사용 시 OPENAI_API_KEY 공유