      "type": "string"
    },
    "enabled": {
      "title": "Enabled",
      "type": "boolean"
    },
    "mcp_endpoint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Mcp Endpoint"
    },
    "rate_limit": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rate Limit"
    }
  },
  "required": [
    "tool_id",
    "node_id",
    "risk_class",
    "auth_method",
    "enabled"
